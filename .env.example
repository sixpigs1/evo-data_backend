# ── 应用 ────────OSS_BUCKET_NAME=evo-data
OS# ── Aliyun Region ─────────────────────────────────────────────
ALIYUN_REGION=cn-hangzhou

# ── CORS ───────────────────────────────────────────────────────
# 逗号分隔的允许源
ALLOWED_ORIGINS=http://localhost:3000,https://data.evomind-tech.comNDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_DOMAIN=https://evo-data.oss-cn-hangzhou.aliyuncs.com───────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 数据库 ─────────────────────────────────────────────────
# MySQL 8.0，字符集 utf8mb4
DATABASE_URL=mysql+pymysql://evodata:evodata_password@localhost:3306/evo_data?charset=utf8mb4

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 阿里云 OSS ─────────────────────────────────────────────
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=evo-data
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_DOMAIN=https://evo-data.oss-cn-shanghai.aliyuncs.com

# ── 阿里云 STS ─────────────────────────────────────────────
STS_ROLE_ARN=acs:ram::your-account-id:role/evo-data-upload-role
STS_SESSION_NAME=evo-data-session
STS_DURATION_SECONDS=3600

# ── 阿里云 RAM (Region) ────────────────────────────────────
ALIYUN_REGION=cn-shanghai

# ── 阿里云短信 ─────────────────────────────────────────────
# 如果使用阿里云短信服务，填写以下配置
SMS_ACCESS_KEY_ID=your-sms-access-key-id
SMS_ACCESS_KEY_SECRET=your-sms-access-key-secret
SMS_SIGN_NAME=EvoData
# 三种短信场景对应的模板 CODE
SMS_TEMPLATE_LOGIN=100001          # 登录/注册验证码
SMS_TEMPLATE_CHANGE_PHONE=100002   # 变更手机号验证码
SMS_TEMPLATE_RESET_PASSWORD=100003 # 重置密码验证码
SMS_CODE_EXPIRE_MINUTES=10         # 验证码有效期（分钟）
# 开发环境设为 true，跳过真实短信发送
SMS_DEV_MODE=true

# ── CORS ───────────────────────────────────────────────────
# 逗号分隔的允许源
ALLOWED_ORIGINS=http://localhost:3000,https://mint-sjtu.github.io

# ── 限流 ───────────────────────────────────────────────────
RATE_LIMIT_SMS=5        # 每手机号每小时最多发送次数
RATE_LIMIT_LOGIN=10     # 每IP每分钟最多登录尝试次数

# ── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
